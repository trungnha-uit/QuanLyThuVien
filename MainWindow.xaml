<Window x:Class="LibraryManagementFE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LibraryManagementFE.Views"
        Title="Hệ thống Quản lý Thư viện – UIT"
        MinWidth="1100" MinHeight="700"
        Width="1280" Height="820"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar 256px fixed -->
            <ColumnDefinition Width="256"/>
            <!-- Main area fills rest -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═════════════════════════════════════════
             SIDEBAR
        ═════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource WhiteBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0"
                Panel.ZIndex="10">
            <DockPanel>

                <!-- ── Logo ── -->
                <StackPanel DockPanel.Dock="Top" Margin="24,24,24,32">
                    <StackPanel Orientation="Horizontal">
                        <!-- UIT logo placeholder -->
                        <Border Width="40" Height="40" CornerRadius="8"
                                Background="{StaticResource BrandDeepBrush}"
                                Margin="0,0,12,0">
                            <TextBlock Text="UIT"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource WhiteBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="THƯ VIỆN"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource BrandDeepBrush}"/>
                            <TextBlock Text="UIT Library System"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- ── Logout (dock bottom) ── -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="12,16">
                    <Button Style="{StaticResource NavLink.Danger}"
                            HorizontalAlignment="Stretch"
                            Click="BtnLogout_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="15" Height="15" Margin="0,0,12,0">
                                <Canvas Width="15" Height="15">
                                    <Path Data="M5 13H2a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1h3"
                                          Stroke="#BA1A1A" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                    <Path Data="M10 11l4-4-4-4M14 7.5H6"
                                          Stroke="#BA1A1A" StrokeThickness="1.5" StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Đăng xuất"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource DangerBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>

                <!-- ── Nav links ── -->
                <StackPanel DockPanel.Dock="Top" Margin="12,0">

                    <!-- Dashboard (inactive = slate; active ⇒ trắng — màu cập nhật trong Nav_Click) -->
                    <Button x:Name="NavDashboard"
                            Style="{StaticResource NavLink.Active}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,4"
                            Click="Nav_Click" Tag="dashboard">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="15" Height="15" Margin="0,0,12,0">
                                <Canvas Width="15" Height="15">
                                    <Rectangle x:Name="NavDashSq1" Width="6" Height="6" RadiusX="1" RadiusY="1" Fill="White"/>
                                    <Rectangle x:Name="NavDashSq2" Canvas.Left="9" Width="6" Height="6" RadiusX="1" RadiusY="1" Fill="White"/>
                                    <Rectangle x:Name="NavDashSq3" Canvas.Top="9" Width="6" Height="6" RadiusX="1" RadiusY="1" Fill="White"/>
                                    <Rectangle x:Name="NavDashSq4" Canvas.Left="9" Canvas.Top="9" Width="6" Height="6" RadiusX="1" RadiusY="1" Fill="White"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock x:Name="NavDashboardTitle"
                                       Text="Tổng quan"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource WhiteBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Sách -->
                    <Button x:Name="NavBooks"
                            Style="{StaticResource NavLink}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,4"
                            Click="Nav_Click" Tag="books">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="19" Height="14" Margin="0,0,12,0">
                                <Canvas Width="19" Height="14">
                                    <Rectangle Canvas.Left="0.75" Canvas.Top="0.75" Width="7.5" Height="12.5" RadiusX="1" RadiusY="1"
                                               Stroke="#64748B" StrokeThickness="1.5" Fill="Transparent"/>
                                    <Rectangle Canvas.Left="10.75" Canvas.Top="0.75" Width="7.5" Height="12.5" RadiusX="1" RadiusY="1"
                                               Stroke="#64748B" StrokeThickness="1.5" Fill="Transparent"/>
                                    <Line X1="9.5" Y1="2" X2="9.5" Y2="12" Stroke="#64748B" StrokeThickness="1.5"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock x:Name="NavBooksTitle"
                                       Text="Sách"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Độc giả -->
                    <Button x:Name="NavReaders"
                            Style="{StaticResource NavLink}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,4"
                            Click="Nav_Click" Tag="readers">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="19" Height="14" Margin="0,0,12,0">
                                <Canvas Width="19" Height="14">
                                    <Ellipse Canvas.Left="1.75" Canvas.Top="0.75" Width="8.5" Height="8.5"
                                             Stroke="#64748B" StrokeThickness="1.5" Fill="Transparent"/>
                                    <Path Data="M0 14 Q0 9 6 9 Q12 9 12 14"
                                          Stroke="#64748B" StrokeThickness="1.5" StrokeLineJoin="Round" Fill="Transparent"/>
                                    <Ellipse Canvas.Left="12.5" Canvas.Top="0.75" Width="6" Height="6"
                                             Stroke="#64748B" StrokeThickness="1.4" Fill="Transparent"/>
                                    <Path Data="M12 14 Q12 11 15.5 11"
                                          Stroke="#64748B" StrokeThickness="1.4" StrokeLineJoin="Round" Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock x:Name="NavReadersTitle"
                                       Text="Độc giả"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Mượn/Trả -->
                    <Button x:Name="NavBorrow"
                            Style="{StaticResource NavLink}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,4"
                            Click="Nav_Click" Tag="borrow">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="17" Height="14" Margin="0,0,12,0">
                                <Canvas Width="17" Height="14">
                                    <Line X1="1" Y1="7" X2="14" Y2="7" Stroke="#64748B" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Path Data="M10 3 L14 7 L10 11" Stroke="#64748B" StrokeThickness="1.5" StrokeLineJoin="Round" Fill="Transparent"/>
                                    <Line X1="16" Y1="1" X2="16" Y2="13" Stroke="#64748B" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock x:Name="NavBorrowTitle"
                                       Text="Mượn/Trả"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Báo cáo -->
                    <!-- Quy định -->
                    <Button x:Name="NavRules"
                            Style="{StaticResource NavLink}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,4"
                            Click="Nav_Click" Tag="rules">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="17" Height="14" Margin="0,0,12,0">
                                <Canvas Width="17" Height="14">
                                    <Rectangle Canvas.Left="2" Canvas.Top="2" Width="13" Height="10"
                                               RadiusX="2" RadiusY="2"
                                               Stroke="#64748B" StrokeThickness="1.5" Fill="Transparent"/>
                                    <Line X1="5" Y1="6" X2="12" Y2="6" Stroke="#64748B" StrokeThickness="1.2"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Line X1="5" Y1="9" X2="10" Y2="9" Stroke="#64748B" StrokeThickness="1.2"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock x:Name="NavRulesTitle"
                                       Text="Quy định"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavReports"
                            Style="{StaticResource NavLink}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,4"
                            Click="Nav_Click" Tag="reports">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="15" Height="15" Margin="0,0,12,0">
                                <Canvas Width="15" Height="15">
                                    <Rectangle Canvas.Left="0.75" Canvas.Top="0.75" Width="13.5" Height="13.5" RadiusX="2" RadiusY="2"
                                               Stroke="#64748B" StrokeThickness="1.5" Fill="Transparent"/>
                                    <Line X1="4" Y1="5.5" X2="11" Y2="5.5" Stroke="#64748B" StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Line X1="4" Y1="8"   X2="11" Y2="8"   Stroke="#64748B" StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Line X1="4" Y1="10.5" X2="8" Y2="10.5" Stroke="#64748B" StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock x:Name="NavReportsTitle"
                                       Text="Báo cáo"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═════════════════════════════════════════
             MAIN AREA (TopBar + Content)
        ═════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <!-- TopBar (~69px incl. vertical padding per Figma) -->
                <RowDefinition Height="69"/>
                <!-- Content fills rest -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── TOP BAR ── -->
            <Border Grid.Row="0"
                    Background="{StaticResource WhiteBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Panel.ZIndex="5"
                    Padding="0,14">
                <Grid Margin="32,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Page title -->
                    <TextBlock x:Name="PageTitle"
                               Grid.Column="0"
                               Text="Tổng quan Hệ thống"
                               FontFamily="{StaticResource InterFont}"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>

                    <!-- Right: icons + divider + user -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <!-- Search button -->
                        <Button Style="{StaticResource IconButton}"
                                ToolTip="Tìm kiếm" Margin="0,0,4,0">
                            <Viewbox Width="16" Height="20">
                                <Canvas Width="16" Height="20">
                                    <Ellipse Canvas.Left="1" Canvas.Top="1" Width="12" Height="12"
                                             Stroke="#64748B" StrokeThickness="1.5" Fill="Transparent"/>
                                    <Line X1="11" Y1="11" X2="15" Y2="15"
                                          Stroke="#64748B" StrokeThickness="1.5"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                        </Button>

                        <!-- Notification button -->
                        <Button Style="{StaticResource IconButton}"
                                ToolTip="Thông báo" Margin="0,0,24,0">
                            <Viewbox Width="20" Height="20">
                                <Canvas Width="20" Height="20">
                                    <Path Data="M10 2a6 6 0 0 0-6 6v3l-2 2.5h16L16 11V8a6 6 0 0 0-6-6Z"
                                          Stroke="#64748B" StrokeThickness="1.5" Fill="Transparent" StrokeLineJoin="Round"/>
                                    <Path Data="M8 17a2 2 0 0 0 4 0"
                                          Stroke="#64748B" StrokeThickness="1.5" Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                        </Button>

                        <!-- Divider -->
                        <Rectangle Width="1" Height="32"
                                   Fill="{StaticResource BorderBrush}"
                                   Margin="0,0,24,0"/>

                        <!-- User info + avatar -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel VerticalAlignment="Center" Margin="0,0,12,0"
                                        HorizontalAlignment="Right">
                                <TextBlock Text="Nguyễn Văn A"
                                           FontFamily="{StaticResource InterFont}"
                                           FontSize="12" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Right"/>
                                <TextBlock Text="ADMIN"
                                           FontFamily="{StaticResource InterFont}"
                                           FontSize="10" FontWeight="Medium"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Right"/>
                            </StackPanel>

                            <!-- Avatar circle -->
                            <Border Width="36" Height="36" CornerRadius="9999"
                                    Background="{StaticResource Brand200Brush}"
                                    BorderBrush="#33004A99" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="2"
                                                      Direction="270" Color="#000000" Opacity="0.15"/>
                                </Border.Effect>
                                <TextBlock Text="NA"
                                           FontFamily="{StaticResource InterFont}"
                                           FontSize="12" FontWeight="Bold"
                                           Foreground="{StaticResource BrandDeepBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── PAGE CONTENT (swappable) ── -->
            <ContentControl x:Name="PageContent"
                            Grid.Row="1"
                            Background="{StaticResource BgBrush}">
                <views:DashboardView/>
            </ContentControl>

        </Grid>
    </Grid>
</Window>
