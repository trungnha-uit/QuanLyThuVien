<Window x:Class="LibraryManagementFE.Views.ConfirmDeleteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Xác nhận xóa"
        Width="440"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        Background="Transparent">
    <Window.Resources>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="104"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontFamily" Value="{StaticResource InterFont}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="112"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontFamily" Value="{StaticResource InterFont}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#B91C1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="0"
            Padding="24"
            Background="{StaticResource WhiteBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <Border Width="44"
                        Height="44"
                        CornerRadius="22"
                        Background="#FEE2E2"
                        Margin="0,0,14,0">
                    <TextBlock Text="!"
                               FontFamily="{StaticResource InterFont}"
                               FontSize="24"
                               FontWeight="Black"
                               Foreground="#DC2626"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TitleTextBlock"
                               Text="Xác nhận xóa"
                               FontFamily="{StaticResource InterFont}"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="SubtitleTextBlock"
                               Margin="0,4,0,0"
                               FontFamily="{StaticResource InterFont}"
                               FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Grid.Row="2"
                       x:Name="MessageTextBlock"
                       TextWrapping="Wrap"
                       FontFamily="{StaticResource InterFont}"
                       FontSize="14"
                       LineHeight="21"
                       Foreground="{StaticResource TextSecondaryBrush}"/>

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Hủy"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,12,0"
                        IsCancel="True"/>
                <Button Content="Xóa"
                        Style="{StaticResource DangerButton}"
                        IsDefault="True"
                        Click="ConfirmButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
