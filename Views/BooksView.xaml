<UserControl x:Class="LibraryManagementFE.Views.BooksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LibraryManagementFE.ViewModels"
             xmlns:models="clr-namespace:LibraryManagementFE.Models"
             Background="#F8FAFC">

    <UserControl.DataContext>
        <vm:BooksViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32" Orientation="Vertical">
            <!-- Figma: Main header + subtitle -->
            <StackPanel Margin="0,0,0,24">
                <TextBlock FontFamily="{StaticResource InterFont}"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           LineHeight="32"
                           Text="Danh mục sách"/>
                <TextBlock Margin="0,4,0,0"
                           FontFamily="{StaticResource InterFont}"
                           FontSize="14"
                           Foreground="{StaticResource TextMutedBrush}"
                           LineHeight="20"
                           TextWrapping="Wrap"
                           Text="Quản lý và theo dõi tất cả đầu sách trong kho."/>
            </StackPanel>

            <!-- Toolbar: search | filter | primary -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="300"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Viewbox Width="18" Height="18"
                             HorizontalAlignment="Left" VerticalAlignment="Center"
                             Margin="16,0,0,0" Panel.ZIndex="1">
                        <Canvas Width="18" Height="18">
                            <Ellipse Canvas.Left="1" Canvas.Top="1" Width="12" Height="12"
                                     Stroke="#94A3B8" StrokeThickness="1.5" Fill="Transparent"/>
                            <Line X1="11" Y1="11" X2="17" Y2="17"
                                  Stroke="#94A3B8" StrokeThickness="1.5"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Viewbox>
                    <TextBox Style="{StaticResource Books.SearchTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Tìm tên sách, tác giả, thể loại..."
                               Margin="48,0,16,0" VerticalAlignment="Center"
                               FontFamily="{StaticResource InterFont}" FontSize="14"
                               Foreground="#6B7280" IsHitTestVisible="False" Panel.ZIndex="1">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Button Grid.Column="2" Style="{StaticResource Books.OutlineToolbarButton}"
                        Command="{Binding FilterCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="18" Height="18" Margin="0,0,8,0">
                            <Canvas Width="18" Height="14">
                                <Line X1="2" Y1="4" X2="16" Y2="4" Stroke="#334155" StrokeThickness="1.4"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="4" Y1="9" X2="14" Y2="9" Stroke="#334155" StrokeThickness="1.4"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="6" Y1="12" X2="12" Y2="12" Stroke="#334155" StrokeThickness="1.4"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Bộ lọc" VerticalAlignment="Center"
                                   FontFamily="{StaticResource InterFont}"
                                   FontSize="16" FontWeight="SemiBold" Foreground="#334155"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="4" Style="{StaticResource Books.PrimaryButton}"
                        Command="{Binding AddBookCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="14" Height="14" Margin="0,0,8,0">
                            <Canvas Width="14" Height="14">
                                <Line X1="7" Y1="2" X2="7" Y2="12" Stroke="White" StrokeThickness="1.8"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="2" Y1="7" X2="12" Y2="7" Stroke="White" StrokeThickness="1.8"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Thêm sách"
                                   VerticalAlignment="Center"
                                   FontFamily="{StaticResource InterFont}"
                                   FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Table card -->
            <Border Background="{StaticResource WhiteBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="16" Margin="0,0,0,32">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="1"
                                      Direction="270" Color="#000000" Opacity="0.05"/>
                </Border.Effect>

                <StackPanel>
                    <DataGrid ItemsSource="{Binding PagedBooks}"
                              Height="556"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserResizeColumns="True"
                              CanUserReorderColumns="False"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F1F5F9"
                              VerticalGridLinesBrush="Transparent"
                              Background="Transparent"
                              BorderThickness="0"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              FontFamily="{StaticResource InterFont}"
                              FontSize="14"
                              ColumnHeaderStyle="{StaticResource Books.DataGridColumnHeader}"
                              RowStyle="{StaticResource Books.DataGridRow}"
                              CellStyle="{StaticResource DataGridCellStyle}">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="STT"
                                                Binding="{Binding Stt}"
                                                Width="64">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource Text.Body}">
                                        <Setter Property="Foreground" Value="#475569"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="SÁCH" Width="*" MinWidth="260">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type models:BookRecord}">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="40" Height="56" CornerRadius="4"
                                                    Background="#F1F5F9"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1" Margin="0,0,12,0"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding CoverImagePath}"
                                                           Stretch="UniformToFill">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasCoverImage}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                    <TextBlock Text="{Binding CoverInitials}"
                                                               FontFamily="{StaticResource InterFont}"
                                                               FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasCoverImage}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="{Binding Title}"
                                                       FontFamily="{StaticResource InterFont}"
                                                       FontSize="14" FontWeight="Bold"
                                                       Foreground="#141C29"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center"
                                                       MaxWidth="320"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="TÁC GIẢ" Width="*" MinWidth="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type models:BookRecord}">
                                        <TextBlock Text="{Binding Author}"
                                                   FontFamily="{StaticResource InterFont}"
                                                   FontSize="14"
                                                   Foreground="#475569"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="THỂ LOẠI" Width="112">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type models:BookRecord}">
                                        <Border Padding="12,8" CornerRadius="9999"
                                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                                Background="{Binding CategoryPillBg, Converter={StaticResource ColorHexConverter}}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding CategoryLine1}"
                                                           FontFamily="{StaticResource InterFont}"
                                                           FontSize="10" FontWeight="Bold"
                                                           TextAlignment="Right"
                                                           HorizontalAlignment="Right"
                                                           Foreground="{Binding CategoryPillFg, Converter={StaticResource ColorHexConverter}}"/>
                                                <TextBlock Text="{Binding CategoryLine2}"
                                                           FontFamily="{StaticResource InterFont}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="{Binding CategoryPillFg, Converter={StaticResource ColorHexConverter}}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="92">
                                <DataGridTemplateColumn.Header>
                                    <StackPanel HorizontalAlignment="Left">
                                        <TextBlock Text="NĂM" FontFamily="{StaticResource InterFont}"
                                                   FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                                        <TextBlock Text="XB" FontFamily="{StaticResource InterFont}"
                                                   FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                                    </StackPanel>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type models:BookRecord}">
                                        <TextBlock Text="{Binding Year}"
                                                   FontFamily="{StaticResource InterFont}"
                                                   FontSize="14" Foreground="#475569"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="TRẠNG THÁI" Width="128">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type models:BookRecord}">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center"
                                                     Fill="{Binding StatusDotColor, Converter={StaticResource ColorHexConverter}}"/>
                                            <TextBlock Text="{Binding StatusText}"
                                                       FontFamily="{StaticResource InterFont}"
                                                       FontSize="14" FontWeight="Medium"
                                                       VerticalAlignment="Center"
                                                       Foreground="{Binding StatusTextColor, Converter={StaticResource ColorHexConverter}}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="112">
                                <DataGridTemplateColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource Books.DataGridColumnHeader}">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTemplateColumn.HeaderStyle>
                                <DataGridTemplateColumn.Header>
                                    <TextBlock Text="THAO TÁC"
                                               FontFamily="{StaticResource InterFont}"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource TextMutedBrush}"/>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type models:BookRecord}">
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <Button Style="{StaticResource Books.RowIconButton}"
                                                    Command="{Binding DataContext.EditBookCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Chỉnh sửa">
                                                <Viewbox Width="18" Height="18">
                                                    <Canvas Width="18" Height="18">
                                                        <Path Data="M11 4H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-7"
                                                              Stroke="#94A3B8" StrokeThickness="1.4" Fill="Transparent"
                                                              StrokeLineJoin="Round"/>
                                                        <Path Data="M16.5 2.5a2.12 2.12 0 0 0-3 3L8 11v3h3l5.5-5.5a2.12 2.12 0 0 0 0-3Z"
                                                              Stroke="#94A3B8" StrokeThickness="1.4" Fill="Transparent"
                                                              StrokeLineJoin="Round"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Button>
                                            <Button Style="{StaticResource Books.RowIconButton}"
                                                    Command="{Binding DataContext.DeleteBookCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Xóa">
                                                <Viewbox Width="16" Height="18">
                                                    <Canvas Width="16" Height="18">
                                                        <Path Data="M2 4h12M6 4V2.5A1.5 1.5 0 0 1 7.5 1h1A1.5 1.5 0 0 1 10 2.5V4M4 4l1 12a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1l1-12"
                                                              Stroke="#94A3B8" StrokeThickness="1.4" Fill="Transparent"
                                                              StrokeLineJoin="Round"/>
                                                        <Line X1="6.5" Y1="8" X2="7" Y2="14" Stroke="#94A3B8" StrokeThickness="1.4" StrokeStartLineCap="Round"/>
                                                        <Line X1="9.5" Y1="8" X2="9" Y2="14" Stroke="#94A3B8" StrokeThickness="1.4" StrokeStartLineCap="Round"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Pagination -->
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                            Background="{StaticResource WhiteBrush}"
                            CornerRadius="0,0,16,16"
                            Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding PaginationInfo}"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="14"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Style="{StaticResource Books.PageNavButton}"
                                        Command="{Binding PrevPageCommand}" Margin="0,0,4,0"
                                        ToolTip="Trang trước">
                                    <Viewbox Width="8" Height="12">
                                        <Canvas Width="8" Height="12">
                                            <Path Data="M6 2 L2 6 L6 10" Stroke="#475569" StrokeThickness="1.6"
                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Fill="Transparent"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                                <ItemsControl ItemsSource="{Binding PageNumbers}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Number}"
                                                    Command="{Binding DataContext.GoToPageCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Number}"
                                                    Margin="0,0,4,0">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource Books.PageNumberButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                <Setter Property="Background" Value="#005AB4"/>
                                                                <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Style="{StaticResource Books.PageNavButton}"
                                        Command="{Binding NextPageCommand}"
                                        ToolTip="Trang sau">
                                    <Viewbox Width="8" Height="12">
                                        <Canvas Width="8" Height="12">
                                            <Path Data="M2 2 L6 6 L2 10" Stroke="#475569" StrokeThickness="1.6"
                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Fill="Transparent"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Stats row (3 cards) -->
            <UniformGrid Columns="3" Margin="0,0,0,32">
                <!-- Tổng đầu sách -->
                <Border Style="{StaticResource Card}" Margin="0,0,8,0" Padding="24" CornerRadius="16">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="48" Height="48" CornerRadius="12" Background="#EFF6FF" Margin="0,0,16,0">
                            <Viewbox Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="20" Height="20">
                                    <Rectangle Canvas.Left="2" Canvas.Top="2" Width="16" Height="16" RadiusX="2" RadiusY="2"
                                               Stroke="#1978E5" StrokeThickness="1.5" Fill="Transparent"/>
                                    <Line X1="5" Y1="7" X2="15" Y2="7" Stroke="#1978E5" StrokeThickness="1.2"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Line X1="5" Y1="10" X2="15" Y2="10" Stroke="#1978E5" StrokeThickness="1.2"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Line X1="5" Y1="13" X2="11" Y2="13" Stroke="#1978E5" StrokeThickness="1.2"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="TỔNG ĐẦU SÁCH"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding TotalBooksDisplay}"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="24" FontWeight="Black"
                                       Foreground="#141C29"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Nhập trong tháng -->
                <Border Style="{StaticResource Card}" Margin="4,0,4,0" Padding="24" CornerRadius="16">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="48" Height="48" CornerRadius="12" Background="#ECFDF5" Margin="0,0,16,0">
                            <Viewbox Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="18" Height="18">
                                    <Path Data="M4 9.5 L7.5 13 L14 5"
                                          Stroke="#059669" StrokeThickness="1.8"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="NHẬP TRONG THÁNG"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding NewThisMonthDisplay}"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="24" FontWeight="Black"
                                       Foreground="#141C29"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Sách đang mượn -->
                <Border Style="{StaticResource Card}" Margin="8,0,0,0" Padding="24" CornerRadius="16">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="48" Height="48" CornerRadius="12" Background="#FFF7ED" Margin="0,0,16,0">
                            <Viewbox Width="20" Height="17" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="20" Height="17">
                                    <Path Data="M3 2.5h14a1 1 0 0 1 1 1v11a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1v-11a1 1 0 0 1 1-1Z"
                                          Stroke="#EA580C" StrokeThickness="1.4" Fill="Transparent" StrokeLineJoin="Round"/>
                                    <Line X1="7" Y1="6" X2="13" Y2="6" Stroke="#EA580C" StrokeThickness="1.2"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="SÁCH ĐANG MƯỢN"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding BorrowedDisplay}"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="24" FontWeight="Black"
                                       Foreground="#141C29"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
